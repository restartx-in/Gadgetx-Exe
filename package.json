{
  "name": "gadgetx-desktop",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"cd gadgetx && npm run dev\" \"cd gadgetx-server && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "migrate": "cd gadgetx-server && npm run migrate",
    "build-frontend": "cd gadgetx && npm run build",
    "build-electron": "electron-builder",
    "dist": "npm run build-frontend && npm run build-electron"
  },
  "build": {
    "appId": "com.gadgetx.desktop",
    "productName": "Gadget X",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "gadgetx/dist/**/*",
      "gadgetx-server/**/*"
    ],
    "asarUnpack": [
      "gadgetx-server/**/*"
    ],
    "extraFiles": [
      {
        "from": "gadgetx-server/gadgetx.db",
        "to": "gadgetx-server/gadgetx.db"
      }
    ],
    "win": {
      "target": "portable",
      "forceCodeSigning": false
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
